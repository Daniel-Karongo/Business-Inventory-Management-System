            <textField>
                <reportElement x="0" y="52" width="782" height="16" uuid="44444444-aaaa-bbbb-cccc-444444444444"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA["Supplier: " + $P{SUPPLIER_NAME}]]></textFieldExpression>
            </textField>

        </band>
