<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="supplier_statement_multi_branch"
              language="java"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="782"
              leftMargin="30"
              rightMargin="30"
              topMargin="30"
              bottomMargin="30"
              uuid="f7b96f11-ecb5-4a28-9d31-5b91c7110001">

    <property name="net.sf.jasperreports.when.no.data.type" value="NoDataSection"/>

    <parameter name="COMPANY_NAME" class="java.lang.String"/>
    <parameter name="SUPPLIER_NAME" class="java.lang.String"/>
    <parameter name="GENERATED_BY" class="java.lang.String"/>
    <parameter name="GENERATED_AT" class="java.util.Date"/>

    <queryString>
        <![CDATA[]]>
    </queryString>

    <field name="transactionDate" class="java.time.LocalDateTime"/>
    <field name="branchName" class="java.lang.String"/>
    <field name="documentType" class="java.lang.String"/>
    <field name="documentNumber" class="java.lang.String"/>
    <field name="referenceNumber" class="java.lang.String"/>
    <field name="description" class="java.lang.String"/>
    <field name="debitAmount" class="java.math.BigDecimal"/>
    <field name="creditAmount" class="java.math.BigDecimal"/>
    <field name="runningBalance" class="java.math.BigDecimal"/>

    <variable name="BranchDebitTotal"
              class="java.math.BigDecimal"
              calculation="Sum"
              resetType="Group"
              resetGroup="BranchGroup">
        <variableExpression><![CDATA[$F{debitAmount}]]></variableExpression>
    </variable>

    <variable name="BranchCreditTotal"
              class="java.math.BigDecimal"
              calculation="Sum"
              resetType="Group"
              resetGroup="BranchGroup">
        <variableExpression><![CDATA[$F{creditAmount}]]></variableExpression>
    </variable>

    <variable name="GrandDebitTotal"
              class="java.math.BigDecimal"
              calculation="Sum">
        <variableExpression><![CDATA[$F{debitAmount}]]></variableExpression>
    </variable>

    <variable name="GrandCreditTotal"
              class="java.math.BigDecimal"
              calculation="Sum">
        <variableExpression><![CDATA[$F{creditAmount}]]></variableExpression>
    </variable>

    <group name="BranchGroup">

        <groupExpression><![CDATA[$F{branchName}]]></groupExpression>

        <groupHeader>
            <band height="24">

                <textField>
                    <reportElement x="0" y="2" width="782" height="20" uuid="11111111-aaaa-bbbb-cccc-111111111111"/>
                    <textElement>
                        <font size="12" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA["Branch: " + $F{branchName}]]></textFieldExpression>
                </textField>

            </band>
        </groupHeader>

    </group>

    <title>
