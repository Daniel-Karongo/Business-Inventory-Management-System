            <staticText>
                <reportElement x="650" y="0" width="132" height="20" uuid="bbbbbbbb-aaaa-bbbb-cccc-bbbbbbbbbbbb"/>
                <textElement textAlignment="Right"><font isBold="true"/></textElement>
                <text><![CDATA[Running Balance]]></text>
            </staticText>

        </band>
    </columnHeader>

    <detail>
        <band height="20">

            <textField pattern="dd MMM yyyy">
                <reportElement x="0" y="0" width="100" height="18" uuid="cccccccc-aaaa-bbbb-cccc-cccccccccccc"/>
                <textFieldExpression><![CDATA[java.sql.Timestamp.valueOf($F{transactionDate})]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="100" y="0" width="110" height="18" uuid="dddddddd-aaaa-bbbb-cccc-dddddddddddd"/>
