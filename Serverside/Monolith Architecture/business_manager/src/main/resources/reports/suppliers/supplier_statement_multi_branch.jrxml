            <staticText>
                <reportElement x="0" y="30" width="782" height="20" uuid="33333333-aaaa-bbbb-cccc-333333333333"/>
                <textElement textAlignment="Center">
                    <font size="13" isBold="true"/>
                </textElement>
                <text><![CDATA[SUPPLIER STATEMENT - MULTI BRANCH]]></text>
