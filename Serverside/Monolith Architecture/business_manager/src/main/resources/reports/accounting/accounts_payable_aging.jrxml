    <!-- ===================================================== -->
    <!-- VARIABLES -->
    <!-- ===================================================== -->

    <variable
            name="GrandTotal"
            class="java.math.BigDecimal"
            calculation="Sum">

        <variableExpression>
            <![CDATA[$F{totalOutstanding}]]>
        </variableExpression>

    </variable>

