            class="java.lang.String"/>

    <parameter
            name="GENERATED_AT"
            class="java.util.Date"/>

    <!-- ===================================================== -->
    <!-- QUERY -->
    <!-- ===================================================== -->

    <queryString>
        <![CDATA[]]>
    </queryString>

    <!-- ===================================================== -->
    <!-- FIELDS -->
    <!-- ===================================================== -->

    <field
            name="supplierName"
            class="java.lang.String"/>

    <field
            name="current"
            class="java.math.BigDecimal"/>

    <field
            name="days1To30"
            class="java.math.BigDecimal"/>

    <field
