<?xml version="1.0" encoding="UTF-8"?>

<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
http://jasperreports.sourceforge.net/jasperreports
http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"

        name="tax_audit_trail"
        pageWidth="842"
        pageHeight="595"
        orientation="Landscape"
        columnWidth="762"
        leftMargin="40"
        rightMargin="40"
        topMargin="30"
        bottomMargin="30">

    <parameter name="BRANCH_ID" class="java.lang.String"/>
    <parameter name="TENANT_ID" class="java.lang.String"/>
    <parameter name="START_DATE" class="java.sql.Date"/>
    <parameter name="END_DATE" class="java.sql.Date"/>

    <parameter name="COMPANY_NAME" class="java.lang.String"/>
    <parameter name="GENERATED_BY" class="java.lang.String"/>
    <parameter name="GENERATED_AT" class="java.util.Date"/>

    <queryString>
        <![CDATA[

SELECT

    je.reference,
    je.sourceModule,
    je.description,

    je.accountingDate,

    le.posted_at,

    a.code,
    a.name,
    a.role,
    a.type,

    le.direction,
    le.amount,

    je.postedBy

FROM ledger_entries le

INNER JOIN journal_entries je
        ON je.id = le.journal_entry_id

INNER JOIN accounts a
        ON a.id = le.account_id

WHERE je.branch_id = $P{BRANCH_ID}
AND je.tenant_id = $P{TENANT_ID}

AND je.posted = 1
AND je.reversed = 0

AND a.role IN (
    'VAT_OUTPUT',
    'VAT_INPUT',
    'VAT_PAYABLE',
    'VAT_RECEIVABLE',
    'VAT_CARRY_FORWARD',
    'CORPORATE_TAX_EXPENSE',
    'CORPORATE_TAX_PAYABLE'
)

AND je.accountingDate BETWEEN
        $P{START_DATE}
        AND
        $P{END_DATE}

ORDER BY
        je.accountingDate,
        le.posted_at,
        je.reference

        ]]>
    </queryString>

    <field name="reference" class="java.lang.String"/>
    <field name="sourceModule" class="java.lang.String"/>
    <field name="description" class="java.lang.String"/>

    <field name="accountingDate" class="java.sql.Date"/>
    <field name="posted_at" class="java.sql.Timestamp"/>

    <field name="code" class="java.lang.String"/>
    <field name="name" class="java.lang.String"/>
    <field name="role" class="java.lang.String"/>
    <field name="type" class="java.lang.String"/>

    <field name="direction" class="java.lang.String"/>
    <field name="amount" class="java.math.BigDecimal"/>

    <field name="postedBy" class="java.lang.String"/>

    <title>
        <band height="70">

            <textField>
                <reportElement x="0" y="0" width="762" height="25"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[
                    "Tax Audit Trail"
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="30" width="762" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[
                    $P{COMPANY_NAME}
                ]]></textFieldExpression>
            </textField>

        </band>
    </title>

    <columnHeader>
        <band height="25">

            <staticText>
                <reportElement x="0" y="0" width="70" height="20"/>
                <text><![CDATA[Acct Date]]></text>
            </staticText>

            <staticText>
                <reportElement x="70" y="0" width="90" height="20"/>
                <text><![CDATA[Posted]]></text>
            </staticText>

            <staticText>
                <reportElement x="160" y="0" width="90" height="20"/>
                <text><![CDATA[Reference]]></text>
            </staticText>

            <staticText>
                <reportElement x="250" y="0" width="90" height="20"/>
                <text><![CDATA[Module]]></text>
            </staticText>

            <staticText>
                <reportElement x="340" y="0" width="80" height="20"/>
                <text><![CDATA[Account]]></text>
            </staticText>

            <staticText>
                <reportElement x="420" y="0" width="120" height="20"/>
                <text><![CDATA[Role]]></text>
            </staticText>

            <staticText>
                <reportElement x="540" y="0" width="50" height="20"/>
                <text><![CDATA[Dr/Cr]]></text>
            </staticText>

            <staticText>
                <reportElement x="590" y="0" width="90" height="20"/>
                <text><![CDATA[Amount]]></text>
            </staticText>

            <staticText>
                <reportElement x="680" y="0" width="82" height="20"/>
                <text><![CDATA[User]]></text>
            </staticText>

        </band>
    </columnHeader>

    <detail>
        <band height="22">

            <textField pattern="yyyy-MM-dd">
                <reportElement x="0" y="0" width="70" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{accountingDate}
                ]]></textFieldExpression>
            </textField>

            <textField pattern="yyyy-MM-dd HH:mm">
                <reportElement x="70" y="0" width="90" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{posted_at}
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="160" y="0" width="90" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{reference}
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="250" y="0" width="90" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{sourceModule}
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="340" y="0" width="80" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{code}
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="420" y="0" width="120" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{role}
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="540" y="0" width="50" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{direction}
                ]]></textFieldExpression>
            </textField>

            <textField pattern="#,##0.00">
                <reportElement x="590" y="0" width="90" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{amount}
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="680" y="0" width="82" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{postedBy}
                ]]></textFieldExpression>
            </textField>

        </band>
    </detail>

    <pageFooter>
        <band height="25">

            <textField>
                <reportElement x="0" y="0" width="220" height="20"/>
                <textFieldExpression><![CDATA[
                    "Generated By: " + $P{GENERATED_BY}
                ]]></textFieldExpression>
            </textField>

            <textField pattern="yyyy-MM-dd HH:mm">
                <reportElement x="250" y="0" width="180" height="20"/>
                <textFieldExpression><![CDATA[
                    $P{GENERATED_AT}
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="650" y="0" width="112" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    "Page " + $V{PAGE_NUMBER}
                ]]></textFieldExpression>
            </textField>

        </band>
    </pageFooter>

    <summary>
        <band height="60">

            <staticText>
                <reportElement x="0" y="10" width="150" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Total Entries]]></text>
            </staticText>

            <textField>
                <reportElement x="160" y="10" width="100" height="20"/>
                <textFieldExpression><![CDATA[
                    $V{REPORT_COUNT}
                ]]></textFieldExpression>
            </textField>

        </band>
    </summary>

    <noData>
        <band height="120">

            <staticText>
                <reportElement x="0" y="40" width="762" height="30"/>
                <textElement textAlignment="Center">
                    <font size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[No tax audit transactions found for the selected period.]]></text>
            </staticText>

        </band>
    </noData>

</jasperReport>