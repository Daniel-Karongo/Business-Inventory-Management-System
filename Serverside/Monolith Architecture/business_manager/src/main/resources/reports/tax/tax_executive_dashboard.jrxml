<?xml version="1.0" encoding="UTF-8"?>

<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
http://jasperreports.sourceforge.net/jasperreports
http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"

        name="tax_executive_dashboard"
        pageWidth="842"
        pageHeight="595"
        orientation="Landscape"
        columnWidth="762"
        leftMargin="40"
        rightMargin="40"
        topMargin="30"
        bottomMargin="30">

    <parameter name="BRANCH_ID" class="java.lang.String"/>
    <parameter name="TENANT_ID" class="java.lang.String"/>
    <parameter name="COMPANY_NAME" class="java.lang.String"/>
    <parameter name="GENERATED_BY" class="java.lang.String"/>
    <parameter name="GENERATED_AT" class="java.util.Date"/>

    <queryString>
        <![CDATA[

SELECT

    COALESCE(
        (
            SELECT balance
            FROM account_balances ab
            INNER JOIN accounts a
                ON a.id = ab.account_id
            WHERE ab.branch_id = $P{BRANCH_ID}
            AND a.role = 'VAT_PAYABLE'
            LIMIT 1
        ),
        0
    ) AS vat_payable,

    COALESCE(
        (
            SELECT balance
            FROM account_balances ab
            INNER JOIN accounts a
                ON a.id = ab.account_id
            WHERE ab.branch_id = $P{BRANCH_ID}
            AND a.role = 'VAT_CARRY_FORWARD'
            LIMIT 1
        ),
        0
    ) AS vat_credit,

    COALESCE(
        (
            SELECT SUM(amount)
            FROM vat_refunds
            WHERE branch_id = $P{BRANCH_ID}
                AND tenant_id = $P{TENANT_ID}
                AND status = 'REQUESTED'
        ),
        0
    ) AS pending_refunds,

    COALESCE(
        (
            SELECT SUM(outstanding_amount)
            FROM corporate_tax_filing
            WHERE branch_id = $P{BRANCH_ID}
                AND tenant_id = $P{TENANT_ID}
                AND status IN (
                    'ACCRUED',
                    'PARTIALLY_PAID',
                    'OVERDUE'
            )
        ),
        0
    ) AS outstanding_corporate_tax,

    COALESCE(
        (
            SELECT SUM(amount)
            FROM vat_payment
            WHERE branch_id = $P{BRANCH_ID}
            AND tenant_id = $P{TENANT_ID}
        ),
        0
    )
    +
    COALESCE(
        (
            SELECT SUM(amount)
            FROM corporate_tax_payment
            WHERE branch_id = $P{BRANCH_ID}
            AND tenant_id = $P{TENANT_ID}
        ),
        0
    ) AS total_tax_paid,

    (
        SELECT COUNT(*)
        FROM vat_filings
        WHERE branch_id = $P{BRANCH_ID}
        AND tenant_id = $P{TENANT_ID}
    ) AS total_vat_returns,

    (
        SELECT COUNT(*)
        FROM corporate_tax_filing
        WHERE branch_id = $P{BRANCH_ID}
        AND tenant_id = $P{TENANT_ID}
    ) AS total_corporate_returns,

    (
        SELECT COUNT(*)
        FROM accounting_periods ap
        WHERE ap.branch_id = $P{BRANCH_ID}
            AND ap.tenant_id = $P{TENANT_ID}
            AND ap.closed = 1
            AND NOT EXISTS (
                SELECT 1
                FROM vat_filings vf
                WHERE vf.period_id = ap.id
                AND vf.branch_id = ap.branch_id
                AND vf.tenant_id = ap.tenant_id
            )
    ) AS pending_vat_returns,

    (
        SELECT COUNT(*)
        FROM accounting_periods
        WHERE branch_id = $P{BRANCH_ID}
            AND tenant_id = $P{TENANT_ID}
            AND closed = 1
            AND tax_accrued = 0
    ) AS pending_corporate_accruals

        ]]>
    </queryString>

    <field name="vat_payable" class="java.math.BigDecimal"/>
    <field name="vat_credit" class="java.math.BigDecimal"/>
    <field name="pending_refunds" class="java.math.BigDecimal"/>
    <field name="outstanding_corporate_tax" class="java.math.BigDecimal"/>
    <field name="total_tax_paid" class="java.math.BigDecimal"/>

    <field name="total_vat_returns" class="java.lang.Long"/>
    <field name="total_corporate_returns" class="java.lang.Long"/>

    <field name="pending_vat_returns" class="java.lang.Long"/>
    <field name="pending_corporate_accruals" class="java.lang.Long"/>

    <title>

        <band height="80">

            <textField>
                <reportElement x="0" y="0" width="762" height="25"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[
                    "Tax Executive Dashboard"
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="35" width="762" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[
                    $P{COMPANY_NAME}
                ]]></textFieldExpression>
            </textField>

        </band>

    </title>

    <detail>

        <band height="260">

            <staticText>
                <reportElement x="20" y="10" width="250" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Current VAT Payable]]></text>
            </staticText>

            <textField pattern="#,##0.00">
                <reportElement x="280" y="10" width="180" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{vat_payable}
                ]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="40" width="250" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Available VAT Credit]]></text>
            </staticText>

            <textField pattern="#,##0.00">
                <reportElement x="280" y="40" width="180" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{vat_credit}
                ]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="70" width="250" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Pending VAT Refunds]]></text>
            </staticText>

            <textField pattern="#,##0.00">
                <reportElement x="280" y="70" width="180" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{pending_refunds}
                ]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="100" width="250" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Outstanding Corporate Tax]]></text>
            </staticText>

            <textField pattern="#,##0.00">
                <reportElement x="280" y="100" width="180" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{outstanding_corporate_tax}
                ]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="130" width="250" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Total Tax Paid]]></text>
            </staticText>

            <textField pattern="#,##0.00">
                <reportElement x="280" y="130" width="180" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{total_tax_paid}
                ]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="165" width="762" height="1"/>
            </line>

            <staticText>
                <reportElement x="20" y="180" width="250" height="20"/>
                <text><![CDATA[VAT Returns Filed]]></text>
            </staticText>

            <textField>
                <reportElement x="280" y="180" width="100" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{total_vat_returns}
                ]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="205" width="250" height="20"/>
                <text><![CDATA[Corporate Returns Filed]]></text>
            </staticText>

            <textField>
                <reportElement x="280" y="205" width="100" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{total_corporate_returns}
                ]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="420" y="180" width="250" height="20"/>
                <text><![CDATA[Pending VAT Filings]]></text>
            </staticText>

            <textField>
                <reportElement x="670" y="180" width="70" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{pending_vat_returns}
                ]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="420" y="205" width="250" height="20"/>
                <text><![CDATA[Pending Corporate Accruals]]></text>
            </staticText>

            <textField>
                <reportElement x="670" y="205" width="70" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{pending_corporate_accruals}
                ]]></textFieldExpression>
            </textField>

        </band>

    </detail>

    <pageFooter>

        <band height="25">

            <textField>
                <reportElement x="0" y="0" width="220" height="20"/>
                <textFieldExpression><![CDATA[
                    "Generated By: " + $P{GENERATED_BY}
                ]]></textFieldExpression>
            </textField>

            <textField pattern="yyyy-MM-dd HH:mm">
                <reportElement x="250" y="0" width="180" height="20"/>
                <textFieldExpression><![CDATA[
                    $P{GENERATED_AT}
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="650" y="0" width="112" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    "Page " + $V{PAGE_NUMBER}
                ]]></textFieldExpression>
            </textField>

        </band>

    </pageFooter>

    <summary>

        <band height="40">

            <staticText>
                <reportElement x="0" y="10" width="762" height="20"/>
                <textElement textAlignment="Center">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[
Tax Position Summary Generated Successfully
                ]]></text>
            </staticText>

        </band>

    </summary>

    <noData>

        <band height="120">

            <staticText>
                <reportElement x="0" y="40" width="762" height="30"/>
                <textElement textAlignment="Center">
                    <font size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[
No tax information available for this branch.
                ]]></text>
            </staticText>

        </band>

    </noData>

</jasperReport>