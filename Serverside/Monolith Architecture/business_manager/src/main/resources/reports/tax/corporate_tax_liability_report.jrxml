<?xml version="1.0" encoding="UTF-8"?>

<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
http://jasperreports.sourceforge.net/jasperreports
http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"

        name="corporate_tax_liability_report"
        pageWidth="842"
        pageHeight="595"
        orientation="Landscape"
        columnWidth="762"
        leftMargin="40"
        rightMargin="40"
        topMargin="30"
        bottomMargin="30">

    <parameter name="BRANCH_ID" class="java.lang.String"/>
    <parameter name="TENANT_ID" class="java.lang.String"/>
    <parameter name="COMPANY_NAME" class="java.lang.String"/>
    <parameter name="GENERATED_BY" class="java.lang.String"/>
    <parameter name="GENERATED_AT" class="java.util.Date"/>

    <queryString>
        <![CDATA[

SELECT

    ctf.id,

    ap.start_date,
    ap.end_date,

    ctf.taxable_profit,
    ctf.tax_rate,
    ctf.tax_amount,

    ctf.paid_amount,
    ctf.outstanding_amount,

    ctf.status,

    ctf.filed_by,
    ctf.filed_at,
    ctf.paid_at

FROM corporate_tax_filing ctf

INNER JOIN accounting_periods ap
    ON ap.id = ctf.period_id

WHERE ctf.branch_id = $P{BRANCH_ID}
AND ctf.tenant_id = $P{TENANT_ID}

ORDER BY
    ap.end_date DESC

        ]]>
    </queryString>

    <field name="id" class="java.util.UUID"/>

    <field name="start_date" class="java.sql.Date"/>
    <field name="end_date" class="java.sql.Date"/>

    <field name="taxable_profit" class="java.math.BigDecimal"/>
    <field name="tax_rate" class="java.math.BigDecimal"/>
    <field name="tax_amount" class="java.math.BigDecimal"/>

    <field name="paid_amount" class="java.math.BigDecimal"/>
    <field name="outstanding_amount" class="java.math.BigDecimal"/>

    <field name="status" class="java.lang.String"/>

    <field name="filed_by" class="java.lang.String"/>
    <field name="filed_at" class="java.sql.Timestamp"/>
    <field name="paid_at" class="java.sql.Timestamp"/>

    <variable name="TOTAL_ACCRUED"
              class="java.math.BigDecimal"
              calculation="Sum">

        <variableExpression><![CDATA[
            $F{tax_amount}
        ]]></variableExpression>

    </variable>

    <variable name="TOTAL_PAID"
              class="java.math.BigDecimal"
              calculation="Sum">

        <variableExpression><![CDATA[
            $F{paid_amount}
        ]]></variableExpression>

    </variable>

    <variable name="TOTAL_OUTSTANDING"
              class="java.math.BigDecimal"
              calculation="Sum">

        <variableExpression><![CDATA[
            $F{outstanding_amount}
        ]]></variableExpression>

    </variable>

    <title>

        <band height="70">

            <textField>
                <reportElement x="0" y="0" width="762" height="25"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[
                    "Corporate Tax Liability Report"
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="30" width="762" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[
                    $P{COMPANY_NAME}
                ]]></textFieldExpression>
            </textField>

        </band>

    </title>

    <columnHeader>

        <band height="25">

            <staticText>
                <reportElement x="0" y="0" width="90" height="20"/>
                <text><![CDATA[Period Start]]></text>
            </staticText>

            <staticText>
                <reportElement x="90" y="0" width="90" height="20"/>
                <text><![CDATA[Period End]]></text>
            </staticText>

            <staticText>
                <reportElement x="180" y="0" width="120" height="20"/>
                <text><![CDATA[Taxable Profit]]></text>
            </staticText>

            <staticText>
                <reportElement x="300" y="0" width="70" height="20"/>
                <text><![CDATA[Rate]]></text>
            </staticText>

            <staticText>
                <reportElement x="370" y="0" width="100" height="20"/>
                <text><![CDATA[Tax Due]]></text>
            </staticText>

            <staticText>
                <reportElement x="470" y="0" width="100" height="20"/>
                <text><![CDATA[Paid]]></text>
            </staticText>

            <staticText>
                <reportElement x="570" y="0" width="100" height="20"/>
                <text><![CDATA[Outstanding]]></text>
            </staticText>

            <staticText>
                <reportElement x="670" y="0" width="92" height="20"/>
                <text><![CDATA[Status]]></text>
            </staticText>

        </band>

    </columnHeader>

    <detail>

        <band height="22">

            <textField pattern="yyyy-MM-dd">
                <reportElement x="0" y="0" width="90" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{start_date}
                ]]></textFieldExpression>
            </textField>

            <textField pattern="yyyy-MM-dd">
                <reportElement x="90" y="0" width="90" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{end_date}
                ]]></textFieldExpression>
            </textField>

            <textField pattern="#,##0.00">
                <reportElement x="180" y="0" width="120" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{taxable_profit}
                ]]></textFieldExpression>
            </textField>

            <textField pattern="0.00%">
                <reportElement x="300" y="0" width="70" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{tax_rate}
                ]]></textFieldExpression>
            </textField>

            <textField pattern="#,##0.00">
                <reportElement x="370" y="0" width="100" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{tax_amount}
                ]]></textFieldExpression>
            </textField>

            <textField pattern="#,##0.00">
                <reportElement x="470" y="0" width="100" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{paid_amount}
                ]]></textFieldExpression>
            </textField>

            <textField pattern="#,##0.00">
                <reportElement x="570" y="0" width="100" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $F{outstanding_amount}
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="670" y="0" width="92" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{status}
                ]]></textFieldExpression>
            </textField>

        </band>

    </detail>

    <pageFooter>

        <band height="25">

            <textField>
                <reportElement x="0" y="0" width="220" height="20"/>
                <textFieldExpression><![CDATA[
                    "Generated By: " + $P{GENERATED_BY}
                ]]></textFieldExpression>
            </textField>

            <textField pattern="yyyy-MM-dd HH:mm">
                <reportElement x="250" y="0" width="180" height="20"/>
                <textFieldExpression><![CDATA[
                    $P{GENERATED_AT}
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="650" y="0" width="112" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    "Page " + $V{PAGE_NUMBER}
                ]]></textFieldExpression>
            </textField>

        </band>

    </pageFooter>

    <summary>

        <band height="120">

            <staticText>
                <reportElement x="0" y="10" width="150" height="20"/>
                <text><![CDATA[Total Accrued Tax]]></text>
            </staticText>

            <textField pattern="#,##0.00">
                <reportElement x="170" y="10" width="150" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $V{TOTAL_ACCRUED}
                ]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="40" width="150" height="20"/>
                <text><![CDATA[Total Paid Tax]]></text>
            </staticText>

            <textField pattern="#,##0.00">
                <reportElement x="170" y="40" width="150" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $V{TOTAL_PAID}
                ]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="70" width="150" height="20"/>
                <text><![CDATA[Outstanding Tax]]></text>
            </staticText>

            <textField pattern="#,##0.00">
                <reportElement x="170" y="70" width="150" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[
                    $V{TOTAL_OUTSTANDING}
                ]]></textFieldExpression>
            </textField>

        </band>

    </summary>

    <noData>

        <band height="120">

            <staticText>
                <reportElement x="0" y="40" width="762" height="30"/>
                <textElement textAlignment="Center">
                    <font size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[
No corporate tax filings exist for this branch.
                ]]></text>
            </staticText>

        </band>

    </noData>

</jasperReport>